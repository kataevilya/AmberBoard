<%- include('header') %>

<!-- Каноничная табличная форма -->
<div class="postForm">
    <form id="new-thread-form">
        <table>
            <tbody>
                <tr>
                    <td>Name</td>
                    <td><input type="text" id="post-name" placeholder="Anonymous"></td>
                </tr>
                <tr>
                    <td>Subject</td>
                    <td>
                        <input type="text" id="post-subject">
                        <input type="submit" value="Submit">
                    </td>
                </tr>
                <tr>
                    <td>Comment</td>
                    <td>
                        <textarea id="post-text" rows="4" required></textarea>
                        
                        <!-- Старые эмодзи как на 4pda -->
                        <div class="emoji-panel">
                            <span class="emoji" data-smile=":)">🙂</span>
                            <span class="emoji" data-smile=":D">😀</span>
                            <span class="emoji" data-smile=";)">😉</span>
                            <span class="emoji" data-smile="pP">😋</span>
                            <span class="emoji" data-smile="B)">😎</span>
                            <span class="emoji" data-smile="O_o">🙄</span>
                            <span class="emoji" data-smile="X(">😡</span>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td>File</td>
                    <td><input type="file" id="post-file"></td>
                </tr>
            </tbody>
        </table>
    </form>
</div>

<hr>

<!-- Контейнер для постов -->
<div id="threads-container">
    <div class="postContainer" id="p1">
        <div class="reply">
            <div class="postInfo">
                <span class="name">Anonymous</span> 
                <span class="dateTime">17/07/26(Fri)13:00:00</span> 
                <span class="postNum">
                    <a href="#p1">No.</a><a href="#p1">1</a>
                </span>
                <!-- Кнопка копирования ссылки -->
                <button class="share-btn" data-id="1">[🔗 Скопировать ссылку]</button>
            </div>
            <div class="postMessage">
                <span class="greentext">>А вот и нормальная архитектура подъехала</span><br>
                Теперь мы используем EJS-шаблоны и каноничный Yotsuba B дизайн с градиентами.
            </div>
        </div>
    </div>
</div>

<%- include('footer') %>